# SupportMind test environment example
# Used by live integration tests and CI service containers.

DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ragdb
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

REDIS_URL=redis://localhost:6379/0
REDIS_POOL_MAX=10

JWT_SECRET_KEY=test-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

GOOGLE_CLIENT_ID=test-client-id
GOOGLE_CLIENT_SECRET=test-client-secret
API_BASE_URL=http://localhost:8000

SENDGRID_API_KEY=test-sendgrid-key
EMAIL_FROM=noreply@supportmind.local
EMAIL_FROM_NAME=SupportMind Test

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=rag-docs
MINIO_SECURE=false

CHROMA_HOST=localhost
CHROMA_PORT=8001

OPENROUTER_API_KEY=test-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512

OPENAI_API_KEY=test-openai-key
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSIONS=1536

JINA_API_KEY=test-jina-key
JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual
JINA_RERANKER_TOP_N=5

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_PER_DAY=10000

FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENVIRONMENT=test
LOG_LEVEL=INFO
